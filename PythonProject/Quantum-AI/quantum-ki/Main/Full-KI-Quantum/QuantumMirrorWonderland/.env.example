# Quantum Mirror Wonderland - Environment Configuration
# Copy this to .env for local development

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change_me_in_production_to_a_random_string
JWT_SECRET_KEY=change_me_in_production_to_another_random_string

# Database
DATABASE_URL=sqlite:///quantum_mirror.db
# PostgreSQL (Production):
# DATABASE_URL=postgresql://quantum_user:password@postgres:5432/quantum_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
PORT=5000
HOST=0.0.0.0

# Security
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Optional: Third-party APIs
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...

