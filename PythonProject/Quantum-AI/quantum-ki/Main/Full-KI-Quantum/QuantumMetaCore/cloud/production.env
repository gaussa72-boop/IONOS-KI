# Quantum Meta Core - Production Environment Configuration
# Use this for production deployments

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_LOG_LEVEL=INFO

# Security - CHANGE THESE!
SECRET_KEY=generate_a_secure_random_string_here_at_least_32_characters
JWT_SECRET_KEY=generate_another_secure_random_string_here_at_least_32_characters

# Database - PostgreSQL Production
DATABASE_URL=postgresql://quantum_user:YOUR_SECURE_PASSWORD@postgres:5432/quantum_db

# Redis - Caching
REDIS_URL=redis://redis:6379/0

# Domain Configuration
DOMAIN=quantummeta.example.com
APP_URL=https://quantummeta.example.com

# Email Configuration (optional)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your_email_password

# API Keys (for external integrations)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# Monitoring
SENTRY_DSN=https://...
LOG_LEVEL=INFO

# Performance
WORKERS=4
WORKER_CLASS=sync
WORKER_TIMEOUT=120

# Features
ENABLE_GAME_GENERATION=True
ENABLE_VOICE_INTEGRATION=True
ENABLE_EXTERNAL_LLM=False

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=redis://redis:6379/1

